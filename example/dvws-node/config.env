# =============================================================================
# shelob-ng / DVWS-Node — shared configuration
# All scripts source this file. Override by exporting vars before running.
# =============================================================================

# Target — DVWS runs on port 80 by default
export DVWS_URL="${DVWS_URL:-http://localhost:80}"

# Admin user (created at container startup)
export FUZZER_USER="${FUZZER_USER:-admin}"
export FUZZER_PASS="${FUZZER_PASS:-Admin1234!}"

# Second user (for BOLA/IDOR tests)
export VICTIM_USER="${VICTIM_USER:-user2}"
export VICTIM_PASS="${VICTIM_PASS:-User1234!}"

# OpenAPI spec (regenerated inside container by swagger-generator.js)
export SPEC_FILE="${SPEC_FILE:-./swagger-output.json}"

# Directories
export CORPUS_DIR="${CORPUS_DIR:-./corpus}"
export RESULTS_BASE="${RESULTS_BASE:-./results}"

# Payload files
export PAYLOADS_SQLI="${PAYLOADS_SQLI:-../juice-shop/payloads/sqli.txt}"
export PAYLOADS_XSS="${PAYLOADS_XSS:-../juice-shop/payloads/xss.txt}"
export PAYLOADS_NOSQL="${PAYLOADS_NOSQL:-../juice-shop/payloads/nosql.txt}"
export PAYLOADS_CMDI="${PAYLOADS_CMDI:-../juice-shop/payloads/cmdi.txt}"

# Fuzzer binary
export FUZZER="${FUZZER:-../../shelob-ng}"

# Default durations
export DURATION_QUICK="${DURATION_QUICK:-5m}"
export DURATION_STANDARD="${DURATION_STANDARD:-15m}"

export RPS="${RPS:-10}"
