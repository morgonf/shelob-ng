# =============================================================================
# shelob-ng / crAPI — shared configuration
# All scripts source this file. Override by exporting vars before running.
# =============================================================================

# Target — crAPI identity service
export CRAPI_URL="${CRAPI_URL:-http://localhost:8888}"

# Mailhog — for email confirmation during registration
export MAILHOG_URL="${MAILHOG_URL:-http://localhost:8025}"

# Primary user
export FUZZER_USER="${FUZZER_USER:-fuzzer@shelob.local}"
export FUZZER_PASS="${FUZZER_PASS:-Shelob1!}"

# Second user (BOLA victim)
export VICTIM_USER="${VICTIM_USER:-victim@shelob.local}"
export VICTIM_PASS="${VICTIM_PASS:-Victim1!}"

# OpenAPI spec — from the upstream repo after git clone
# Relative path assumes crAPI is cloned as a sibling to shelob-ng:
#   git clone https://github.com/OWASP/crAPI.git /opt/crapi
export SPEC_FILE="${SPEC_FILE:-/opt/crapi/openapi-spec/crapi-openapi-spec.json}"

# Directories
export CORPUS_DIR="${CORPUS_DIR:-./corpus}"
export RESULTS_BASE="${RESULTS_BASE:-./results}"

# Payload files
export PAYLOADS_SQLI="${PAYLOADS_SQLI:-../juice-shop/payloads/sqli.txt}"
export PAYLOADS_XSS="${PAYLOADS_XSS:-../juice-shop/payloads/xss.txt}"
export PAYLOADS_NOSQL="${PAYLOADS_NOSQL:-../juice-shop/payloads/nosql.txt}"

# Fuzzer binary
export FUZZER="${FUZZER:-../../shelob-ng}"

# Default durations
export DURATION_QUICK="${DURATION_QUICK:-5m}"
export DURATION_STANDARD="${DURATION_STANDARD:-15m}"
export DURATION_FULL="${DURATION_FULL:-30m}"

# RPS limit — crAPI is a multi-service app; be conservative
export RPS="${RPS:-10}"
