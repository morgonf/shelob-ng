# =============================================================================
# shelob-ng / Juice Shop — shared configuration
# All scripts source this file. Override by exporting vars before running.
# =============================================================================

# Target
export JUICE_URL="${JUICE_URL:-http://localhost:3000}"
export CSP_URL="${CSP_URL:-http://localhost:8080}"

# Primary user (fuzzer) — created by 01_setup.sh
export FUZZER_USER="${FUZZER_USER:-fuzzer@shelob.local}"
export FUZZER_PASS="${FUZZER_PASS:-Shelob1!}"

# Second user (BOLA victim) — created by 01_setup.sh
export VICTIM_USER="${VICTIM_USER:-victim@shelob.local}"
export VICTIM_PASS="${VICTIM_PASS:-Victim1!}"

# OpenAPI spec (downloaded by 01_setup.sh)
export SPEC_FILE="${SPEC_FILE:-./juice-shop.openapi.json}"

# Directories
export CORPUS_DIR="${CORPUS_DIR:-./corpus}"
export RESULTS_BASE="${RESULTS_BASE:-./results}"

# Payload files
export PAYLOADS_SQLI="${PAYLOADS_SQLI:-./payloads/sqli.txt}"
export PAYLOADS_XSS="${PAYLOADS_XSS:-./payloads/xss.txt}"
export PAYLOADS_SSTI="${PAYLOADS_SSTI:-./payloads/ssti.txt}"
export PAYLOADS_LFI="${PAYLOADS_LFI:-./payloads/lfi.txt}"

# Fuzzer binary (built by make build)
export FUZZER="${FUZZER:-../shelob-ng}"

# Default durations per scenario (override with DURATION=5m make run-full)
export DURATION_QUICK="${DURATION_QUICK:-5m}"
export DURATION_STANDARD="${DURATION_STANDARD:-15m}"
export DURATION_FULL="${DURATION_FULL:-1h}"

# RPS limit (0 = unlimited)
export RPS="${RPS:-0}"
