# =============================================================================
# shelob-ng / RESTler Demo Server — shared configuration
# All scripts source this file. Override by exporting vars before running.
# =============================================================================

# Target — RESTler demo server on port 8888
export DEMO_URL="${DEMO_URL:-http://localhost:8888}"

# OpenAPI spec (downloaded from running server)
export SPEC_FILE="${SPEC_FILE:-./openapi.json}"

# Directories
export CORPUS_DIR="${CORPUS_DIR:-./corpus}"
export RESULTS_BASE="${RESULTS_BASE:-./results}"

# Fuzzer binary
export FUZZER="${FUZZER:-../../shelob-ng}"

# Default durations
export DURATION_QUICK="${DURATION_QUICK:-2m}"
export DURATION_STANDARD="${DURATION_STANDARD:-5m}"

export RPS="${RPS:-20}"
