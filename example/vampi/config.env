# =============================================================================
# shelob-ng / VAmPI — shared configuration
# All scripts source this file. Override by exporting vars before running.
# =============================================================================

# Target
export VAMPI_URL="${VAMPI_URL:-http://localhost:5000}"

# Primary user (admin — has access to all books)
export FUZZER_USER="${FUZZER_USER:-admin1}"
export FUZZER_PASS="${FUZZER_PASS:-pass1}"

# Second user (regular user — used for BOLA probe)
export VICTIM_USER="${VICTIM_USER:-user2}"
export VICTIM_PASS="${VICTIM_PASS:-pass2}"

# OpenAPI spec (fetched by 01_setup.sh from running container)
export SPEC_FILE="${SPEC_FILE:-./openapi3.yaml}"

# Directories
export CORPUS_DIR="${CORPUS_DIR:-./corpus}"
export RESULTS_BASE="${RESULTS_BASE:-./results}"

# Payload files — reuse from juice-shop or provide your own
export PAYLOADS_SQLI="${PAYLOADS_SQLI:-../juice-shop/payloads/sqli.txt}"
export PAYLOADS_XSS="${PAYLOADS_XSS:-../juice-shop/payloads/xss.txt}"
export PAYLOADS_NOSQL="${PAYLOADS_NOSQL:-../juice-shop/payloads/nosql.txt}"

# Fuzzer binary (built at repo root)
export FUZZER="${FUZZER:-../../shelob-ng}"

# Default durations
export DURATION_QUICK="${DURATION_QUICK:-5m}"
export DURATION_STANDARD="${DURATION_STANDARD:-15m}"

# RPS limit — VAmPI is a lightweight Flask app; 20 rps is comfortable
export RPS="${RPS:-20}"
