# =============================================================================
# shelob-ng / Swagger Petstore 3 — shared configuration
# All scripts source this file. Override by exporting vars before running.
# =============================================================================

# Target — Petstore runs on port 8080
export PETSTORE_URL="${PETSTORE_URL:-http://localhost:8080}"

# API key (passed via -apikey flag; any non-empty value works for the
# reference implementation — it validates presence but not the value itself)
export API_KEY="${API_KEY:-special-key}"

# OpenAPI spec (downloaded from running container)
export SPEC_FILE="${SPEC_FILE:-./openapi.yaml}"

# Directories
export CORPUS_DIR="${CORPUS_DIR:-./corpus}"
export RESULTS_BASE="${RESULTS_BASE:-./results}"

# Fuzzer binary
export FUZZER="${FUZZER:-../../shelob-ng}"

# Default durations
export DURATION_QUICK="${DURATION_QUICK:-5m}"
export DURATION_STANDARD="${DURATION_STANDARD:-15m}"

# Petstore is a reference app — limit RPS to avoid overwhelming it
export RPS="${RPS:-10}"
